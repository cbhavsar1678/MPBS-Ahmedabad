rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((request.auth.token.email == "cbhavsar1678@gmail.com" && request.auth.token.email_verified == true) ||
         (request.auth.token.email == "admin@mpbs.com") ||
         (exists(/databases/$(database)/documents/members/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role == 'admin'));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Members
    match /members/{memberId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isAdmin() || isOwner(memberId));
      allow update: if isAuthenticated() && (isAdmin() || isOwner(memberId));
      allow delete: if isAdmin();
    }

    // Family Members
    match /family-members/{fmId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isAdmin() || isOwner(request.resource.data.memberId) || (resource != null && isOwner(resource.data.memberId)));
    }

    // Children
    match /children/{childId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isAdmin() || isOwner(request.resource.data.memberId) || (resource != null && isOwner(resource.data.memberId)));
    }

    // Events
    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Donations
    function isValidDonation(data) {
      return data.memberId is string && data.memberId.size() > 0 &&
             data.amount is number && data.amount >= 0 &&
             data.date is string &&
             (data.paymentType == 'online' || data.paymentType == 'offline');
    }

    match /donations/{donationId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidDonation(request.resource.data);
      allow update: if isAdmin() && isValidDonation(request.resource.data);
      allow delete: if isAdmin();
    }

    // Annual Fees
    function isValidAnnualFee(data) {
      return data.memberId is string && data.memberId.size() > 0 &&
             data.amount is number && data.amount >= 0 &&
             data.date is string &&
             data.year is string &&
             (data.paymentType == 'online' || data.paymentType == 'offline');
    }

    match /annual-fees/{feeId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidAnnualFee(request.resource.data);
      allow update: if isAdmin() && isValidAnnualFee(request.resource.data);
      allow delete: if isAdmin();
    }

    // Teams
    match /teams/{teamId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Event Expenses
    match /event-expenses/{expenseId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Bank Deposits
    function isValidBankDeposit(data) {
      return data.bankName is string && data.bankName.size() > 0 &&
             data.depositorName is string && data.depositorName.size() > 0 &&
             data.depositAmount is number && data.depositAmount >= 0 &&
             data.depositDate is string &&
             data.maturityDate is string;
    }

    match /bank-deposits/{depositId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidBankDeposit(request.resource.data);
      allow update: if isAdmin() && isValidBankDeposit(request.resource.data);
      allow delete: if isAdmin();
    }

    // Profit or Surplus
    function isValidProfitSurplus(data) {
      return data.description is string && data.description.size() > 0 &&
             data.date is string &&
             data.amount is number && data.amount >= 0;
    }

    match /profit-surplus/{profitId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidProfitSurplus(request.resource.data);
      allow update: if isAdmin() && isValidProfitSurplus(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
